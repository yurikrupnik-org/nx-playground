{
  "name": "matia-web",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/matia/web/src",
  "targets": {
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "file": "manifests/dockers/Dockerfile",
        "context": ".",
        "build-args": ["DIST_PATH=apps/matia/web/dist"],
        "tags": ["$REGISTRY/matia-web:latest"],
        "push": false
      },
      "configurations": {
        "ci": {
          "push": true,
          "metadata": {
            "images": ["$REGISTRY/matia-web"],
            "tags": [
              "type=sha",
              "type=ref,event=branch",
              "type=ref,event=pr",
              "type=raw,value=$APP_VERSION,enable=$ENABLE_VERSION"
            ]
          }
        }
      }
    },
    "scan": {
      "executor": "nx:run-commands",
      "dependsOn": ["container"],
      "options": {
        "command": "trivy image $REGISTRY/matia-web:latest --severity CRITICAL,HIGH --exit-code 0",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": []
}
