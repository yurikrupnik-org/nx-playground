        "cwd": "{workspaceRoot}"
      }
    },
    "test:grpc-vs-rest": {
      "executor": "nx:run-commands",
      "options": {
        "command": "k6 run apps/zerg/k6/scenarios/grpc-vs-rest.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:pool-exhaustion": {
      "executor": "nx:run-commands",
      "options": {
        "command": "k6 run apps/zerg/k6/scenarios/pool-exhaustion.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:multi-tenant": {
      "executor": "nx:run-commands",
      "options": {
        "command": "k6 run apps/zerg/k6/scenarios/multi-tenant.js",
