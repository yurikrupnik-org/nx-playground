{
  "name": "zerg-k6",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/zerg/k6",
  "implicitDependencies": ["zerg_api", "zerg_tasks"],
  "targets": {
    "test:auth": {
      "executor": "nx:run-commands",
      "options": {
        "command": "k6 run apps/zerg/k6/scenarios/auth-storm.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "test:crud": {
      "executor": "nx:run-commands",
